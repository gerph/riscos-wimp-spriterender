#include <stdbool.h>
#include <stdint.h>

#include "GContext/gcontext.h"
#include "colourmap.h"

#ifndef APP
#include "modhead.h"
#endif

typedef struct colourmapparams_s {
    bool is_selected;
    bool is_shaded;
    colour_t winbgcolour;
    colour_t selbgcolour;
} colourmapparams_t;

typedef struct colourmapdescriptor_internal_s {
    colourmapdescriptor_t descriptor;

    colourmapparams_t params;
} colourmapdescriptor_internal_t;


static colourmapdescriptor_internal_t desc;

extern void *module_pw;


/*************************************************** Gerph *********
 Function:      colourmap_setup
 Description:   Create us a colour map descriptor for the sprite rendering
 Parameters:    is_selected = true if we are selected
                is_shaded = true if we are shaded
                winbgcolour = the window background
                selbgcolour = the icon background for selections
 Returns:       colour map descriptor to use

 WARNING:       There is only ONE descriptor at present.
 ******************************************************************/
colourmapdescriptor_t *colourmap_setup(bool is_selected,
                                       bool is_shaded,
                                       colour_t winbgcolour,
                                       colour_t selbgcolour)
{
    /* FIXME: We probably also need to handle the tinting operator as well */
    desc.params.is_selected = is_selected;
    desc.params.is_shaded = is_shaded;
    desc.params.winbgcolour = winbgcolour;
    desc.params.selbgcolour = selbgcolour;

    desc.descriptor.pw = module_pw;
#ifdef APP
    desc.descriptor.func = (void*)&ColourMap_Entry;
#else
    desc.descriptor.func = (void*)ColourMap_Entry;
#endif

    return &desc.descriptor;
}


selectalgorithm_t select_algorithm = sela_selectblend;
shadealgorithm_t shade_algorithm = shaa_backgroundblend; //shaa_greyblend; //shaa_grey;


/*************************************************** Gerph *********
 Function:      colourmap_transform
 Description:   Transform the colour we have been given
 Parameters:    colour = &BBGGRR00 to transform
 Returns:       &BBGGRR00 which has been transformed
 ******************************************************************/
colour_t colourmap_transform(colour_t colour)
{
    if (desc.params.is_selected)
    {
        switch (select_algorithm)
        {
            case sela_invert:
                colour = colour ^ 0xFFFFFF00;
                break;

            case sela_selectblend:
                {
                    uint32_t mask = 0x7F7F7F00;
                    uint32_t selbgcolour = desc.params.selbgcolour;
                    colour = (colour>>1) & mask;
                    selbgcolour = (selbgcolour >> 1) & mask;
                    colour = colour + selbgcolour;
                }
                break;
        }
    }

    if (desc.params.is_shaded)
    {
        uint32_t r = (colour>>8) & 0xFF;
        uint32_t g = (colour>>16) & 0xFF;
        uint32_t b = (colour>>24) & 0xFF;

        switch (shade_algorithm)
        {
            case shaa_greyblend:
                // Blend 3/4 towards light grey
                r = (0xDD*3 + r)>>2;
                g = (0xDD*3 + g)>>2;
                b = (0xDD*3 + b)>>2;
                break;

            case shaa_grey:
                // Grey and fade to grey
                {
                    uint32_t grey;
                    r = (colour>>8) & 0xFF;
                    g = (colour>>16) & 0xFF;
                    b = (colour>>24) & 0xFF;
                    grey = (r + g + b) / 3;
                    grey = (0xDD * 3 + grey)>>2;
                    r = grey;
                    g = grey;
                    b = grey;
                }
                break;

            case shaa_backgroundblend:
                // RISC OS Select fade using background colour
                {
                    uint32_t winbgcolour = desc.params.winbgcolour;
                    uint32_t total;
                    uint32_t grey;
                    uint32_t grey_scaled;

                    // Calculate a weighted grey value
                    total = (r * 77) + (g * 150) + (b * 28) + 127;
                    total = total + (total<<8);
                    grey = (total + 0x100) >> 16;

                    grey_scaled = grey * 69;

                    b = (winbgcolour>>24);
                    b = b * 85;  // 85 = 255 / 3
                    b = (b>>7) + 16;
                    b = b + (grey_scaled >> 8);

                    g = (winbgcolour>>16) & 255;
                    g = g * 85;  // 85 = 255 / 3
                    g = (g>>7) + 16;
                    g = g + (grey_scaled >> 8);

                    r = (winbgcolour>>8) & 255;
                    r = r * 85;  // 85 = 255 / 3
                    r = (r>>7) + 16;
                    r = r + (grey_scaled >> 8);
                }
                break;
        }

        colour = (r<<8) | (g<<16) | (b<<24);
    }

    return colour;
}
