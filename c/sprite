/*************************************************** Gerph *********
 Function:      sprite_render
 Description:   Render a sprite on to the screen
 Parameters:    sprite-> the sprite to render
                x0, y0 = bottom left
                scale = the scale factor to use (may be identity)
                plot_action = action for rendering (may include mask bit and wide pixtrans bits)
                pixtrans-> the pixel translation table to use
 Returns:       pointer to error, or NULL if successful
 ******************************************************************/
_kernel_oserror *sprite_render(sprite_t *sprite, int x0, int y0,
                               scale_t scale, int plot_action,
                               pixtrans_t *pixtrans)
{
    _kernel_oserror *err = _swix(OS_SpriteOp, _INR(0, 7),
                                 0x200 + SpriteReason_PutSpriteScaled,
                                 256, sprite,
                                 x0, y0,
                                 plot_action,
                                 &scale, pixtrans);
    dprintf("sprite_render of sprite %p, at %i, %i, with action %i gave: %s\n", sprite, x0, y0, plot_action,
            err ? err->errmess : "<no error>");
    return err;
}

