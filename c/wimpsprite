/*************************************************** Gerph *********
 Function:      wimpsprite_create
 Description:   Create a sprite object for rendering or sizing.
 Parameters:    graphics-> our Wimp graphics context
                sprite-> the sprite we are rendering
                is_halfsize
                is_unscaled
                is_selected
                is_shaded = properties for the render
                window_background
                selection_colour = rendering properties
 Returns:       pointer to a new renderable sprite object
 ******************************************************************/
wimpsprite_t *wimpsprite_create(wimpgraphics_t *graphics, sprite_t *sprite,
                                bool is_halfsize, bool is_unscaled,
                                bool is_selected, bool is_shaded,
                                colour_t window_background,
                                colour_t selection_colour)
{
    wimpsprite_t *wsprite = malloc(sizeof(*wsprite));
    if (wsprite == NULL)
        return NULL;

    wsprite->graphics = graphics;
    wsprite->sprite = sprite;
    wsprite->is_halfsize = is_halfsize;
    wsprite->is_unscaled = is_unscaled;
    wsprite->is_selected = is_selected;
    wsprite->is_shaded = is_shaded;
    wsprite->window_background = window_background;
    wsprite->selection_colour = selection_colour;

    return wsprite;
}


/*************************************************** Gerph *********
 Function:      wimpsprite_getsize
 Description:   Retrieves the size of the sprite we are rendering
 Parameters:    wsprite-> the sprite information to render
 Returns:       a width and height for the bounds
 ******************************************************************/
bounds_t wimpsprite_getsize(wimpsprite_t *wsprite)
{
    bounds_t bounds;
    eigenfactors_t seigen;
    if (wsprite == NULL)
    {
        bounds.width = 0;
        bounds.height = 0;
        return bounds;
    }
    bounds = sprite_getsize(wsprite->sprite);
    seigen = sprite_geteigenfactors(wsprite->sprite);

    bounds.width = bounds.width << seigen.xeig;
    bounds.height = bounds.height << seigen.yeig;

    if (wsprite->is_halfsize)
    {
        bounds.width = bounds.width / 2;
        bounds.height = bounds.height / 2;
    }
    return bounds;
}

/*************************************************** Gerph *********
 Function:      wimpsprite_getscale
 Description:   Read the scale factors to use for a given sprite
 Parameters:    wsprite-> the sprite we want to get the scaling of
 Returns:       the scale factors to use
 ******************************************************************/
scale_t wimpsprite_getscale(wimpsprite_t *wsprite)
{
    scale_t scale;
    eigenfactors_t seigen;
    int render_xpixel = wsprite->graphics->xpixel;
    int render_ypixel = wsprite->graphics->ypixel;
    int sprite_xpixel;
    int sprite_ypixel;
    seigen = sprite_geteigenfactors(wsprite->sprite);

    sprite_xpixel = 1 << seigen.xeig;
    sprite_ypixel = 1 << seigen.yeig;

    if (wsprite->is_halfsize)
    {
        render_xpixel *= 2;
        render_ypixel *= 2;
    }

    if ((render_xpixel == sprite_xpixel && render_ypixel == sprite_ypixel) || wsprite->is_unscaled)
    {
        scale = scale_identity;
    }
    else
    {
        scale.xmult = sprite_xpixel;
        scale.ymult = sprite_ypixel;
        scale.xdiv = render_xpixel;
        scale.ydiv = render_ypixel;
    }

    return scale;
}


/*************************************************** Gerph *********
 Function:      wimpsprite_getpixtrans
 Description:   Read a pixel translation table for the sprite
 Parameters:    wsprite-> the sprite we wish to render
 Returns:       pointer to the wimppixtrans_t for the table, OR NULL if failed
 ******************************************************************/
wimppixtrans_t *wimpsprite_getpixtrans(wimpsprite_t *wsprite)
{
    int32_t plot_action = 0;
    wimppixtrans_t *wpixtrans;
    int src_mode;
    void *src_palette;
    uint32_t flags;
    void *colourmap_func;
    void *colourmap_ws;
    int table_size;

    if (sprite_log2bpp(wsprite->sprite) == 2 && ! sprite_haspalette(wsprite->sprite))
    {
        /* 16 colour sprite without palette, so the palette to use should be the wimp palette */
        src_mode = 27;
        /* FIXME: There are other palettes for the 2 and 4 colour modes? */
        /* FIXME: This should be read from the wimp graphics context */
        src_palette = &current_wimp_palette;
    }
    else
    {
        /* Other depths; use the sprite's own palette */
        src_mode = 256;  /* 256 is a special marker to mean this is a sprite palette */
        src_palette = sprite_address(wsprite->sprite);
    }

    flags = ColourTrans_GivenSprite | ColourTrans_ReturnWideEntries;
    colourmap_func = NULL;
    colourmap_ws = NULL;

    if (wsprite->is_selected || wsprite->is_shaded)
    {
        /* Apply the selection / shading code */
        /* FIXME: This should be implemented as a colourmap descriptor */
        //colourmap_func = wimpcolourmap_apply(wsprite->is_selected, wsprite->is_shaded, wsprite->window_background);
        // flags |= ColourTrans_GivenTransferFn
    }

    table_size = colourtrans_gettablesize(src_mode, src_palette,
                                          ColourTrans_CurrentMode, (void*)ColourTrans_CurrentPalette,
                                          flags);
    /* FIXME: Check for error - and check for 0 table size being no-table */

    wpixtrans = malloc(sizeof(*wpixtrans) + table_size);
    if (wpixtrans == NULL)
        return NULL; /* Failed to allocate, so give up */

    wpixtrans->pixtrans = (char *)wpixtrans + sizeof(*wpixtrans);

    if (!colourtrans_generatetable(src_mode, (void*)src_palette,
                                   ColourTrans_CurrentMode, (void*)ColourTrans_CurrentPalette,
                                   wpixtrans->pixtrans,
                                   flags,
                                   colourmap_func,
                                   colourmap_ws))
    {
        free(wpixtrans);
        return NULL;
    }
    if (wsprite->graphics->log2bpp > 3)
    {
        plot_action |= SpritePlotAction_WideTranslationPresent;
    }

    wpixtrans->plot_action = plot_action;
    return wpixtrans;
}


/*************************************************** Gerph *********
 Function:      wimpsprite_freepixtrans
 Description:   Free the allocated pixel transformation
 Parameters:    wpixtrans-> the wimp pix trans we wish to free
 Returns:       None
 ******************************************************************/
void wimpsprite_freepixtrans(wimppixtrans_t *wpixtrans)
{
    if (wpixtrans)
    {
        /* FIXME: We would decrement the usage count and free here if necessary in the future */
        free(wpixtrans);
    }
}



/*************************************************** Gerph *********
 Function:      wimpsprite_render
 Description:   Render a given sprite to a position, possibly tiled.
 Parameters:    wsprite-> the sprite we wish to render
 Returns:       pointer to error, or NULL if successful
 ******************************************************************/
_kernel_oserror *wimpsprite_render(wimpsprite_t *wsprite, int x0, int y0, bool is_tiled)
{
    scale_t scale = wimpsprite_getscale(wsprite);
    wimppixtrans_t *wpixtrans = wimpsprite_getpixtrans(wsprite);
    int plot_action = wpixtrans->plot_action | SpritePlotAction_UseMask;
    _kernel_oserror *err;

    wimpgraphics_apply_clip(wsprite->graphics);
    if (is_tiled)
        err = sprite_tile(wsprite->sprite, x0, y0, scale, plot_action, wpixtrans->pixtrans);
    else
        err = sprite_render(wsprite->sprite, x0, y0, scale, plot_action, wpixtrans->pixtrans);
    return err;
}
