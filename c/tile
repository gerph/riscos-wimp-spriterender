/* x and y are the bottom left position
   returns 1 if the tile operation should terminate */
typedef int tile_f(void *private, int x, int y, bounds_t *box);


/*************************************************** Gerph *********
 Function:     tile
 Description:  Simple tiling algorithm
 Parameters:   func-> the function to call for tiling
               funcpriv = private value to pass to function
               xo,yo = the origin position
               box-> the bounding box to tile into (expected to
                     be initialised as a graphics window)
 Returns:      none
 ******************************************************************/
static void tile(tile_f func, void *funcpriv,
                 int xo, int yo, int w, int h, bounds_t *box)
{
  int xs,ys,xe,ye;
  if (w <= 0 || h <= 0)
    return;

  /* Work out the origin as a relative position */
  xo = xo % w;  yo = yo % h;
  if (xo<0) xo+=w;
  if (yo<0) yo+=h;

  /* Work out the start relative to the bounding box */
  xs = box->x0 - (box->x0 % w);
  ys = box->y0 - (box->y0 % h);

  if (xo != 0) xs -= w;
  if (yo != 0) ys -= h;

  xs += xo;
  ys += yo;
  xe = box->x1;
  ye = box->y1;

  /* Now do the plotting of each of them */
  {
    int y;

    /* dprintf("Tiling %i,%i - %i,%i in steps of %i,%i\n", */
            /* xs,ys,xe,ye,w,h); */
    for (y=ys; y<ye; y+=h)
    {
      int x;
      for (x=xs; x<xe; x+=w)
      {
        if (func(funcpriv, x, y, box))
          return; /* They wanted to be stopped */
      }
    }
  }
}

