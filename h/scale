#ifndef SCALE_H
#define SCALE_H

#include "GContext/gcontext.h"

typedef struct scale_s {
  int32_t xmult;
  int32_t ymult;
  int32_t xdiv;
  int32_t ydiv;
} scale_t;

extern scale_t scale_identity;

/*************************************************** Gerph *********
 Function:      scale_apply
 Description:   Apply scale factors to a coordinate pair
 Parameters:    scale-> the scaling block to apply
                coords-> the coordinates to update with the scale
 Returns:       none
 ******************************************************************/
void scale_apply(const scale_t *scale, coords_t *coords);

/*************************************************** Gerph *********
 Function:      scale_applybbox
 Description:   Apply scale factors to a bounding box
 Parameters:    scale-> the scaling block to apply
                bbox-> the coordinates to update with the scale
 Returns:       none
 ******************************************************************/
void scale_applybbox(const scale_t *scale, bbox_t *bbox);

#endif
