#ifndef SPRITE_H
#define SPRITE_H

#include <stdint.h>
#include <stdbool.h>

#include "GContext/gcontext.h"

#include "colourtransconstants.h"
#include "types.h"
#include "scale.h"

typedef struct sprite_s {
    uint32_t    offset;         /* Offset to next sprite */
    char        name[12];       /* Sprite name, up to 12 characters with trailing zeroes */
    uint32_t    width_words_1;  /* Width in words -1 */
    uint32_t    height_1;       /* Height in scan lines -1 */
    uint32_t    first_bit;      /* First bit used (left end of row) */
    uint32_t    last_bit;       /* Last bit used (right end of row) */
    uint32_t    offset_bitmap;  /* Offset to sprite image */
    uint32_t    offset_mask;    /* Offset to transparency mask or offset to sprite image if no mask */
    uint32_t    mode;           /* Mode sprite was defined in (see Sprite modes) */
    /* Palette follows on here */
} sprite_t;

#define sprite_address(sprite) (sprite)


/*************************************************** Gerph *********
 Function:      sprite_getsize
 Description:   Read the size of a sprite, in OS units
 Parameters:    sprite-> the sprite to read (as a pointer, not a name)
 Returns:       bounds (as width and height)
 ******************************************************************/
bounds_t sprite_getsize(sprite_t *sprite);

/*************************************************** Gerph *********
 Function:      sprite_geteigenfactors
 Description:   Read the eigenfactors for a given sprite
 Parameters:    sprite-> the sprite to read the factors for
 Returns:       eigenfactors_t object
 ******************************************************************/
eigenfactors_t sprite_geteigenfactors(sprite_t *sprite);

/*************************************************** Gerph *********
 Function:      sprite_log2bpp
 Description:   Read the depth of the sprite as log2bits per pixel
 NOTE:          Does not handle modern sprite types
 Parameters:    var = value
 Returns:       none
 ******************************************************************/
int sprite_log2bpp(sprite_t *sprite);

/*************************************************** Gerph *********
 Function:      sprite_haspalette
 Description:   Does the sprite have a palette?
 Parameters:    sprite-> the sprite to check
 Returns:       true if there is a palette; false if not.
 ******************************************************************/
bool sprite_haspalette(sprite_t *sprite);

/*************************************************** Gerph *********
 Function:      sprite_tile
 Description:   Tile sprites on to the screen
 Parameters:    sprite-> the sprite to render
                x0, y0 = bottom left
                scale = the scale factor to use (may be identity)
                plot_action = action for rendering (may include mask bit and wide pixtrans bits)
                pixtrans-> the pixel translation table to use
 Returns:       pointer to error, or NULL if successful
 ******************************************************************/
_kernel_oserror *sprite_tile(sprite_t *sprite, int x0, int y0,
                             scale_t scale, int plot_action,
                             pixtrans_t *pixtrans);


/*************************************************** Gerph *********
 Function:      sprite_render
 Description:   Render a sprite on to the screen
 Parameters:    sprite-> the sprite to render
                x0, y0 = bottom left
                scale = the scale factor to use (may be identity)
                plot_action = action for rendering (may include mask bit and wide pixtrans bits)
                pixtrans-> the pixel translation table to use
 Returns:       pointer to error, or NULL if successful
 ******************************************************************/
_kernel_oserror *sprite_render(sprite_t *sprite, int x0, int y0,
                               scale_t scale, int plot_action,
                               pixtrans_t *pixtrans);

#endif
